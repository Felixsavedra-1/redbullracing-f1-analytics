[flake8]
max-line-length = 120
extend-ignore =
    # Line too long — SQL strings and format strings routinely exceed 120 chars
    E501,
    # Module-level imports not at top of file — scripts use sys.path.insert pattern
    E402,
    # Line break before binary operator — Black-compatible style
    W503,
    # Whitespace in blank lines — pre-existing style in extract_data.py
    W293,
    # Expected 2 blank lines — pre-existing style throughout
    E302,E303,E305,
    # Multiple spaces before operator/keyword — column-alignment style
    E221,E272,
per-file-ignores =
    # Test files: allow longer lines for assertion messages
    tests/*.py: E501
